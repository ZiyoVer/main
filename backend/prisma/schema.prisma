datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// ============ USERS ============

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Email verification
  emailVerified     Boolean   @default(false)
  verificationToken String?   @unique
  verificationTokenExpiry DateTime?

  // Password reset
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Relations
  chats        Chat[]
  testAttempts TestAttempt[]
  visitLogs    VisitLog[]
  profile      StudentProfile?
  testsCreated Test[]         @relation("TestCreator")
  progress     UserProgress?
  topicStats   TopicStat[]
  flashcards   Flashcard[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationSender")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Onboarding data
  subject      String?
  subject2     String?   // DTM 2-ixtisoslik fani
  examType     String?  // "DTM" | "MS"
  targetScore  Int?
  weakTopics   String?  // JSON string array
  strongTopics String?  // JSON string array
  concerns     String?
  examDate     DateTime?
  studyHoursPerDay Float?

  // Rasch
  abilityLevel Float    @default(0.0)
  totalTests   Int      @default(0)
  avgScore     Float    @default(0.0)

  onboardingDone Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============ CHAT ============

model Chat {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("Yangi Suhbat")
  subject   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId])
  @@index([userId, subject])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String
  content   String
  fileUrl   String?  // Agar fayl yuklangan bo'lsa
  fileType  String?  // "image", "pdf", "word"
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([chatId, createdAt])
}

// ============ TESTS ============

model Test {
  id          String         @id @default(uuid())
  title       String
  description String?
  creatorId   String
  creator     User           @relation("TestCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  isPublic    Boolean        @default(false)
  shareLink   String         @unique @default(uuid())
  subject     String?
  testType    String         @default("milliy_sertifikat") // "milliy_sertifikat" | "dtm"
  timeLimit   Int?           // minutes, null = no limit
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  questions   TestQuestion[]
  attempts    TestAttempt[]

  @@index([isPublic])
  @@index([creatorId])
  @@index([isPublic, createdAt])
  @@index([creatorId, createdAt])
}

model TestQuestion {
  id           String  @id @default(uuid())
  testId       String
  test         Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  text         String
  imageUrl     String?
  options      String  // JSON array: ["A", "B", "C", "D"], "[]" for open-ended
  correctIdx   Int     @default(0) // -1 for open-ended
  correctText  String? // To'g'ri javob matni (open-ended uchun)
  questionType String  @default("mcq") // "mcq" | "open"
  difficulty   Float   @default(0.0)   // Rasch difficulty
  orderIdx     Int     @default(0)
}

model TestAttempt {
  id        String   @id @default(uuid())
  testId    String
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   String   // JSON: [{questionId, selectedIdx, isCorrect}]
  score     Float
  raschAbility Float @default(0.0)
  createdAt DateTime @default(now())

  @@index([testId])
  @@index([userId])
  @@index([testId, userId])
}

// ============ RAG DOCUMENTS ============

model Document {
  id        String          @id @default(uuid())
  fileName  String
  fileType  String          // "pdf", "word", "text"
  fileSize  Int
  subject   String?
  s3Url     String?
  s3Key     String?
  createdAt DateTime        @default(now())
  chunks    DocumentChunk[]

  @@index([subject])
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int
  embedding  String?  // JSON array of floats (vector)
  createdAt  DateTime @default(now())
}

// ============ ANALYTICS ============

model VisitLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // "login", "register", "page_view"
  ip        String?
  createdAt DateTime @default(now())
}

// ============ AI SETTINGS ============

model AISetting {
  id        String   @id @default(uuid())
  key       String   @unique  // "system_prompt_extra", "temperature", "max_tokens", "behavior_rules"
  value     String   // JSON or string value
  updatedAt DateTime @updatedAt
}

// ============ GAMIFICATION ============

model UserProgress {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp             Int       @default(0)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model TopicStat {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  topic         String
  correct       Int       @default(0)
  total         Int       @default(0)
  lastPracticed DateTime?
  createdAt     DateTime  @default(now())

  @@unique([userId, subject, topic])
  @@index([userId])
  @@index([userId, subject])
}

model Flashcard {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  front      String
  back       String
  nextReview DateTime @default(now())
  interval   Int      @default(1)    // kunlar
  ease       Float    @default(2.5)  // SM-2 easiness factor
  repetitions Int     @default(0)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, subject])
  @@index([userId, nextReview])
}

// ============ NOTIFICATIONS ============

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
  title      String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

// ============ KNOWLEDGE BASE ============

model KnowledgeItem {
  id        String   @id @default(uuid())
  subject   String   // "Matematika", "Ona tili", "Fizika", "Kimyo", "Biologiya", "Tarix", "Ingliz tili"
  title     String   // "DTM 2023 - Algebra", "MS 2022 - Morfologiya"
  content   String   // Matn (savollar, formulalar, qoidalar)
  source    String?  // "DTM 2023", "MS 2022", "Darslik"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject])
}
