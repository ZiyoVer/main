# ============ DATABASE ============
# PostgreSQL connection string (Railway yoki boshqa provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============ AUTH ============
# JWT token uchun maxfiy kalit (kamida 32 belgi, random string)
JWT_SECRET=your-very-secret-jwt-key-here

# ============ AI ============
# OpenAI API key (platform.openai.com) — rasm tahlili (GPT-4o Vision) uchun
OPENAI_API_KEY=sk-...

# DeepSeek API key (platform.deepseek.com) — matn/chat uchun (V3 + R1)
DEEPSEEK_API_KEY=sk-...

# ============ SERVER ============
PORT=8080
NODE_ENV=production

# ============ CORS ============
# Vergul bilan ajratilgan ruxsat berilgan originlar
# Masalan: https://msert.uz,https://www.msert.uz
ALLOWED_ORIGINS=https://msert.uz

# ============ ADMIN ============
# Birinchi ishga tushirishda admin yaratiladi (ikkisi ham MAJBURIY)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# ============ AWS S3 (optional — fayl yuklash uchun) ============
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
