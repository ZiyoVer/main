# ============ DATABASE ============
# PostgreSQL connection string (Railway yoki boshqa provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============ AUTH ============
# JWT token uchun maxfiy kalit (kamida 32 belgi, random string)
JWT_SECRET=your-very-secret-jwt-key-here

# ============ AI ============
# Gemini API key (aistudio.google.com) — ASOSIY: chat + test generatsiya + vision/OCR.
# Model: gemini-3.5-flash (OpenAI-mos endpoint). Railway'da o'rnatilishi SHART.
GEMINI_API_KEY=AIza...

# DeepSeek API key (platform.deepseek.com) — ZAXIRA (Gemini ishlamasa avtomatik o'tadi).
# Bo'lmasa ham ishlaydi, lekin Gemini tushganda uzilish bo'lmasligi uchun tavsiya etiladi.
DEEPSEEK_API_KEY=sk-...

# OpenAI API key — endi ishlatilmaydi (vision Gemini'ga ko'chirildi). Ixtiyoriy.
OPENAI_API_KEY=sk-...

# ============ SERVER ============
PORT=8080
NODE_ENV=production

# ============ CORS / FRONTEND ============
# Vergul bilan ajratilgan ruxsat berilgan originlar (live: www + www'siz)
ALLOWED_ORIGINS=https://www.dtmmax.uz,https://dtmmax.uz
# Email (tasdiqlash/parol-tiklash) linklari uchun ASOSIY xost — MAJBURIY, aks holda linklar o'lik
FRONTEND_URL=https://www.dtmmax.uz

# ============ REDIS (logout token blacklist — DURABLE bo'lishi uchun) ============
# REDIS_URL bo'lmasa blacklist xotirada saqlanadi va har restartда yo'qoladi
# (logout qilingan token qayta tiriladi). Productionда Redis ulang.
# REDIS_REQUIRED=true bo'lsa — Redis bo'lmasa server umuman ishga tushmaydi (xavfsiz).
REDIS_URL=redis://default:password@host:6379
REDIS_REQUIRED=true

# ============ GOOGLE OAUTH ("Google bilan kirish") ============
# Google Cloud Console → OAuth Client ID (Web). Faqat ID kerak (secret emas).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ============ BILLING / OBUNA (Paylov hosted checkout) ============
# PRO_ENFORCED=true bo'lganda Pro faqat to'lov qilganlarga ochiladi (default: hammaga ochiq beta)
PRO_ENFORCED=false
# Beta yopilmasdan sandbox checkout sinash: faqat ADMIN akkauntiga ruxsat beradi.
BILLING_SANDBOX_TEST=false
# Pro narxi (so'm)
PRO_PRICE_UZS=35000
# Asosiy provider. Berilmasa merchant_id + Token mavjudligidan Paylov avtomatik tanlanadi.
BILLING_PROVIDER=paylov
# Paylov emailida shu ikki nom bilan keladi. Kod PAYLOV_MERCHANT_ID/PAYLOV_TOKEN
# uppercase aliaslarini ham qabul qiladi.
merchant_id=
Token=
# Paylov'ga ro'yxatdan o'tkaziladigan callback:
# https://BACKEND-DOMAIN/api/billing/paylov/callback
# Login/parolni o'zingiz kuchli random qiymat qilib yarating va Paylov jamoasiga yuboring.
PAYLOV_CALLBACK_LOGIN=
PAYLOV_CALLBACK_PASSWORD=

# OCTO eski/zaxira provider. BILLING_PROVIDER=octo bo'lgandagina ishlaydi.
OCTO_SHOP_ID=
OCTO_SECRET=
# Webhook imzo kaliti (Octo "unique_key" — texnik jamoa beradi). Bo'lmasa OCTO_SECRET ishlatiladi
OCTO_NOTIFY_SECRET=
# Sandbox rejimi: test=true bilan haqiqiy pul yechilmaydi
OCTO_TEST=true
# Imzo tekshiruvini vaqtincha o'chirish (faqat sandbox debug) — default ON
# OCTO_VERIFY_SIGNATURE=false
# (eski/zaxira) umumiy webhook imzo kaliti — bo'lmasa /webhook 503 (inert)
BILLING_WEBHOOK_SECRET=

# ============ EMAIL (Resend — tasdiqlash/parol tiklash) ============
RESEND_API_KEY=re_...
EMAIL_FROM=DTMMax <noreply@dtmmax.uz>

# ============ ADMIN ============
# Birinchi ishga tushirishda admin yaratiladi (ikkisi ham MAJBURIY)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# ============ Rasm saqlash (SAVOL RASMLARI + CHAT RASMLARI SHUNGA BOG'LIQ) ============
# BU KALITLARSIZ rasm yuklash ishlamaydi.
# Kod bir nechta nom variantini o'qiydi, shuning uchun Railway Bucket bilan HECH NARSA
# yozmasdan ishlaydi (Bucket ACCESS_KEY_ID/SECRET_ACCESS_KEY/BUCKET/ENDPOINT/REGION beradi).
# Qo'lda (Wasabi/MinIO) ulasang, quyidagilarni to'ldir:
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-1
