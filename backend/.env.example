# ============ DATABASE ============
# PostgreSQL connection string (Railway yoki boshqa provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============ AUTH ============
# JWT token uchun maxfiy kalit (kamida 32 belgi, random string)
JWT_SECRET=your-very-secret-jwt-key-here

# ============ AI ============
# DeepSeek API key (platform.deepseek.com) — matn/chat uchun (V3 + R1). ASOSIY.
DEEPSEEK_API_KEY=sk-...

# Gemini API key (aistudio.google.com) — rasm/OCR (vision) + DeepSeek-429 fallback uchun.
# Model: gemini-2.5-flash (OpenAI-mos endpoint). Buni Railway'da o'rnatish SHART.
GEMINI_API_KEY=AIza...

# OpenAI API key — endi ishlatilmaydi (vision Gemini'ga ko'chirildi). Ixtiyoriy.
OPENAI_API_KEY=sk-...

# ============ SERVER ============
PORT=8080
NODE_ENV=production

# ============ CORS / FRONTEND ============
# Vergul bilan ajratilgan ruxsat berilgan originlar (live: www + www'siz)
ALLOWED_ORIGINS=https://www.dtmmax.uz,https://dtmmax.uz
# Email (tasdiqlash/parol-tiklash) linklari uchun ASOSIY xost — MAJBURIY, aks holda linklar o'lik
FRONTEND_URL=https://www.dtmmax.uz

# ============ REDIS (logout token blacklist — DURABLE bo'lishi uchun) ============
# REDIS_URL bo'lmasa blacklist xotirada saqlanadi va har restartда yo'qoladi
# (logout qilingan token qayta tiriladi). Productionда Redis ulang.
# REDIS_REQUIRED=true bo'lsa — Redis bo'lmasa server umuman ishga tushmaydi (xavfsiz).
REDIS_URL=redis://default:password@host:6379
REDIS_REQUIRED=true

# ============ GOOGLE OAUTH ("Google bilan kirish") ============
# Google Cloud Console → OAuth Client ID (Web). Faqat ID kerak (secret emas).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ============ BILLING / OBUNA (OCTO agregator — pul yoqilganda) ============
# PRO_ENFORCED=true bo'lganda Pro faqat to'lov qilganlarga ochiladi (default: hammaga ochiq beta)
PRO_ENFORCED=false
# Pro narxi (so'm)
PRO_PRICE_UZS=35000
# OCTO merchant kalitlari (octo.uz onboarding'dan keyin). Bo'lmasa /checkout 503 (inert)
OCTO_SHOP_ID=
OCTO_SECRET=
# Webhook imzo kaliti (Octo "unique_key" — texnik jamoa beradi). Bo'lmasa OCTO_SECRET ishlatiladi
OCTO_NOTIFY_SECRET=
# Sandbox rejimi: test=true bilan haqiqiy pul yechilmaydi
OCTO_TEST=true
# Imzo tekshiruvini vaqtincha o'chirish (faqat sandbox debug) — default ON
# OCTO_VERIFY_SIGNATURE=false
# (eski/zaxira) umumiy webhook imzo kaliti — bo'lmasa /webhook 503 (inert)
BILLING_WEBHOOK_SECRET=

# ============ EMAIL (Resend — tasdiqlash/parol tiklash) ============
RESEND_API_KEY=re_...
EMAIL_FROM=DTMMax <noreply@dtmmax.uz>

# ============ ADMIN ============
# Birinchi ishga tushirishda admin yaratiladi (ikkisi ham MAJBURIY)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# ============ AWS S3 (optional — fayl yuklash uchun) ============
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
